<%- include('partials/header') %>

    <!-- ============ SINGLE PROJECT (all data from the database) ============ -->
    <section class="py-5 flex-grow-1">
        <div class="container">
            <a href="/projects" class="btn btn-link text-decoration-none ps-0 mb-3"><i class="bi bi-arrow-left"></i> Back to all projects</a>

            <div class="row g-4 g-lg-5 align-items-start">
                <div class="col-lg-7">
                    <img src="<%= project.image_url %>" alt="<%= project.title %>" class="img-fluid rounded shadow-sm w-100">
                </div>
                <div class="col-lg-5">
                    <small class="text-muted text-uppercase"><%= project.medium %></small>
                    <h1 class="mt-2 mb-3" style="font-family: 'Playfair Display', serif;"><%= project.title %></h1>
                    <p class="lead"><%= project.description %></p>

                    <hr class="my-4">

                    <dl class="row mb-0">
                        <dt class="col-5 text-muted fw-normal">Edition / Medium</dt>
                        <dd class="col-7"><%= project.medium %></dd>

                        <dt class="col-5 text-muted fw-normal">Price</dt>
                        <dd class="col-7"><%= project.price_eth %> ETH</dd>

                        <dt class="col-5 text-muted fw-normal">Minted</dt>
                        <dd class="col-7"><%= new Date(project.minted_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></dd>
                    </dl>

                    <a href="/contact.html" class="btn btn-dark mt-4">Inquire About This Piece <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
