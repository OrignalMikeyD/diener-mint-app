<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

    <!-- Google Font: Playfair Display for headings -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">

    <!-- Custom styles -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- ============ HEADER / NAVBAR ============ -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Diener Mint</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/#featured">Featured</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="/projects">Projects</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact.html">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ============ SINGLE PROJECT (all data from the database) ============ -->
    <section class="py-5 flex-grow-1">
        <div class="container">
            <a href="/projects" class="btn btn-link text-decoration-none ps-0 mb-3"><i class="bi bi-arrow-left"></i> Back to all projects</a>

            <div class="row g-4 g-lg-5 align-items-start">
                <div class="col-lg-7">
                    <img src="<%= project.image_url %>" alt="<%= project.title %>" class="img-fluid rounded shadow-sm w-100">
                </div>
                <div class="col-lg-5">
                    <small class="text-muted text-uppercase"><%= project.medium %></small>
                    <h1 class="mt-2 mb-3" style="font-family: 'Playfair Display', serif;"><%= project.title %></h1>
                    <p class="lead"><%= project.description %></p>

                    <hr class="my-4">

                    <dl class="row mb-0">
                        <dt class="col-5 text-muted fw-normal">Edition / Medium</dt>
                        <dd class="col-7"><%= project.medium %></dd>

                        <dt class="col-5 text-muted fw-normal">Price</dt>
                        <dd class="col-7"><%= project.price_eth %> ETH</dd>

                        <dt class="col-5 text-muted fw-normal">Minted</dt>
                        <dd class="col-7"><%= new Date(project.minted_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></dd>
                    </dl>

                    <a href="/contact.html" class="btn btn-dark mt-4">Inquire About This Piece <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="mt-auto py-4 bg-dark text-white">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <p class="mb-0">&copy; 2026 Michael Diener. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="https://github.com/OrignalMikeyD" class="text-white me-3 text-decoration-none" aria-label="GitHub profile" target="_blank" rel="noopener">
                        <i class="bi bi-github fs-4"></i>
                    </a>
                    <a href="/contact.html" class="text-white text-decoration-none" aria-label="Contact page">
                        <i class="bi bi-envelope fs-4"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle (Popper included) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
