<%- include('partials/header') %>

    <!-- ============ SPLASH / HERO ============ -->
    <header class="py-5 bg-dark text-white text-center">
        <div class="container py-5">
            <img src="https://placehold.co/180x180/0a0a0a/f5f5f5?text=DM" alt="Diener Mint mark" class="mb-4 rounded-circle" width="150" height="150">
            <h1 class="display-3 fw-bold mb-3" style="font-family: 'Playfair Display', serif;">Generative Sketches, Minted On-Chain</h1>
            <p class="lead col-lg-8 mx-auto mb-4">An experimental NFT project exploring the intersection of code, performance, and ownership.</p>
            <a href="#featured" class="btn btn-light btn-lg px-4">See the Work</a>
        </div>
    </header>

    <!-- ============ FEATURED PROJECT (random, from the database) ============ -->
    <section id="featured" class="py-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-8">
                    <h2 class="mb-0" style="font-family: 'Playfair Display', serif;">Featured Project</h2>
                    <p class="text-muted">A piece from the chain, chosen at random each visit.</p>
                </div>
                <div class="col-md-4 text-md-end align-self-center">
                    <a href="/projects" class="btn btn-outline-dark">View All Projects <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="row g-0">
                    <div class="col-md-6">
                        <img src="<%= featured.image_url %>" alt="<%= featured.title %>" class="img-fluid rounded-start w-100 h-100" style="object-fit: cover;">
                    </div>
                    <div class="col-md-6">
                        <div class="card-body p-4 p-md-5">
                            <small class="text-muted text-uppercase"><%= featured.medium %></small>
                            <h3 class="card-title mt-2 mb-3" style="font-family: 'Playfair Display', serif;"><%= featured.title %></h3>
                            <p class="card-text"><%= featured.description %></p>
                            <a href="/projects/<%= featured.id %>" class="btn btn-dark mt-2">Open Project</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============ ABOUT ============ -->
    <section id="about" class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <img src="https://placehold.co/300x300/2a2a2a/f5f5f5?text=MD" alt="Portrait of Michael Diener" class="img-fluid rounded-circle shadow-sm" width="260">
                </div>
                <div class="col-md-8">
                    <h2 class="mb-3" style="font-family: 'Playfair Display', serif;">About</h2>
                    <p class="lead mb-3">Michael Diener is an artist, performer, and creative technologist based in Phoenix.</p>
                    <p>His work moves between acting, code, and applied behavioral systems. After twelve years in professional acting and prior research work in AI safety, he is now exploring how generative and on-chain tools can hold the same weight as a performance.</p>
                    <p class="mb-4">This project is part of his MA in Creative Technology at SMU Meadows.</p>
                    <a href="/contact.html" class="btn btn-dark">Get in Touch <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
