<%- include('partials/header') %>

    <!-- ============ PROJECTS GRID (rendered from the database) ============ -->
    <section class="py-5 flex-grow-1">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h1 class="mb-0" style="font-family: 'Playfair Display', serif;">Projects</h1>
                <a href="/projects/new" class="btn btn-dark"><i class="bi bi-plus-lg"></i> Add Project</a>
            </div>
            <p class="text-muted mb-5">Generative work, minted on-chain. The collection grows over time.</p>

            <div class="row g-4">
                <%
                // Loop over every project in the array and render one card each.
                // The card links to /projects/<id>, so the id from the database drives the URL.
                projects.forEach((project) => { %>
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <img src="<%= project.image_url %>" alt="<%= project.title %>" class="card-img-top" style="aspect-ratio: 3 / 2; object-fit: cover;">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 card-title" style="font-family: 'Playfair Display', serif;"><%= project.title %></h3>
                                <p class="card-text text-muted small flex-grow-1"><%= project.description %></p>
                                <a href="/projects/<%= project.id %>" class="btn btn-outline-dark btn-sm mt-2 align-self-start">View Project <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
